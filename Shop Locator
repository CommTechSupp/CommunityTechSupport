    <div class="header-top">
      <div>
        <div class="greeting">Near you · NYC</div>
        <div class="title">Repair<br>Shops</div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px;">
        <div class="avatar">AJ</div>
        <div class="loc-badge"><i class="ti ti-map-pin" style="font-size:11px" aria-hidden="true"></i> Lower Manhattan</div>
