    rating:4.2, reviews:309, distance:1.7,
    address:"11 John St, New York, NY 10038",
    website:"https://www.experimax.com/locations/new-york-ny/",
    services:["Mac Repair","Apple Devices","Upgrades","Trade-In"],
    ratingBreakdown:[38,32,20,5,5],
    clientReviews:[
      {author:"Liam F.",stars:5,text:"Best place for Apple repairs, staff really know Macs."},
      {author:"Ava K.",stars:4,text:"Got a great deal on a refurbished MacBook."},
      {author:"Noah G.",stars:4,text:"iMac repair done right, no issues since."}
    ]
  }
];

let currentSort = 'rating';
let activeFilters = new Set(['all']);
let allVisible = [...stores];

function stars(r){
  let s='';
  for(let i=1;i<=5;i++){
    if(i<=Math.floor(r)) s+='<span class="star full">★</span>';
    else if(i-r<1&&i-r>0) s+='<span class="star half">★</span>';
    else s+='<span class="star empty">★</span>';
  }
  return s;
}

function renderCard(store){
  const div=document.createElement('div');
  div.className='card'+(store.topRated?' top':'');
  div.style.cssText='animation:fadeUp .3s ease forwards;opacity:0;';
  div.onclick=()=>openDetail(store);
  div.innerHTML=`
    <div class="card-head">
      <div class="store-name">
        ${store.website?`<a href="${store.website}" target="_blank" rel="noopener" onclick="event.stopPropagation()">${store.name}</a>`:store.name}
      </div>
      <div class="badges">
        ${store.topRated?'<span class="badge-top">Top Rated</span>':''}
        <span class="badge-open ${store.open?'open':'closed'}">${store.open?'Open':'Closed'}</span>
      </div>
    </div>
    <div class="stars-row">
      <div class="stars">${stars(store.rating)}</div>
      <span class="rating-num">${store.rating}</span>
      <span class="review-count">(${store.reviews.toLocaleString()} reviews)</span>
    </div>
    <div class="addr-row">
      <i class="ti ti-map-pin" style="font-size:11px;color:var(--muted)" aria-hidden="true"></i>
      <span class="addr-text">${store.address}</span>
      <span class="dist-badge">${store.distance} mi</span>
    </div>
    <div class="tags">${store.services.map(s=>`<span class="tag">${s}</span>`).join('')}</div>`;
  return div;
}

function renderList(list){
  const c=document.getElementById('cardsContainer');
  c.innerHTML='';
  document.getElementById('resultCount').textContent=`${list.length} shop${list.length!==1?'s':''} found`;
  if(list.length===0){
    document.getElementById('storeList').style.display='none';
    document.getElementById('emptyState').style.display='block';
    return;
  }
  document.getElementById('storeList').style.display='block';
  document.getElementById('emptyState').style.display='none';
  list.forEach((s,i)=>{
    const card=renderCard(s);
    card.style.animationDelay=`${i*60}ms`;
    c.appendChild(card);
  });
}

function getFiltered(){
  const q=document.getElementById('searchInput').value.toLowerCase();
  let list=[...stores];
  if(!activeFilters.has('all')){
    list=list.filter(s=>{
      if(activeFilters.has('open')&&!s.open) return false;
      const devFilters=[...activeFilters].filter(f=>f!=='open');
      if(devFilters.length&&!devFilters.some(f=>s.services.some(sv=>sv.toLowerCase().includes(f.toLowerCase())))) return false;
      return true;
    });
  }
  if(q) list=list.filter(s=>s.name.toLowerCase().includes(q)||s.services.some(sv=>sv.toLowerCase().includes(q)));
  if(currentSort==='rating') list.sort((a,b)=>b.rating-a.rating);
  else if(currentSort==='distance') list.sort((a,b)=>a.distance-b.distance);
  else list.sort((a,b)=>b.reviews-a.reviews);
  return list;
}

function filterStores(){renderList(getFiltered());}

function setSort(type,el){
  currentSort=type;
  document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  filterStores();
}

function toggleFilter(val,el){
  if(val==='all'){
    activeFilters=new Set(['all']);
    document.querySelectorAll('.ftag').forEach(f=>f.classList.remove('on'));
    el.classList.add('on');
  } else {
    activeFilters.delete('all');
    document.querySelector('.ftag').classList.remove('on');
    if(activeFilters.has(val)){activeFilters.delete(val);el.classList.remove('on');}
    else{activeFilters.add(val);el.classList.add('on');}
    if(activeFilters.size===0){activeFilters.add('all');document.querySelector('.ftag').classList.add('on');}
  }
  filterStores();
}

function openDetail(store){
  const bars=store.ratingBreakdown;
  const total=bars.reduce((a,b)=>a+b,0);
  const barsHTML=[5,4,3,2,1].map((n,i)=>`
    <div class="bar-row">
      <span class="bar-label">${n}</span>
      <div class="bar-track"><div class="bar-fill" style="width:${bars[i]}%"></div></div>
      <span style="font-size:10px;color:var(--muted);width:28px;text-align:right">${bars[i]}%</span>
    </div>`).join('');
  const revsHTML=store.clientReviews.map(r=>`
    <div class="review-card">
      <div class="rev-head">
        <span class="rev-author">${r.author}</span>
        <div class="rev-stars">${stars(r.stars)}</div>
      </div>
      <p class="rev-text">${r.text}</p>
    </div>`).join('');
  document.getElementById('detailContent').innerHTML=`
    <div style="display:flex;gap:10px;align-items:flex-start;margin-bottom:4px;">
      <div style="flex:1">
        <div class="detail-title">${store.name}</div>
        <div class="detail-addr"><i class="ti ti-map-pin" style="font-size:11px" aria-hidden="true"></i> ${store.address}</div>
      </div>
      <span class="badge-open ${store.open?'open':'closed'}" style="font-size:11px;padding:4px 10px;">${store.open?'Open Now':'Closed'}</span>
    </div>
    <div class="detail-stars">
      <div class="big-rating">${store.rating}</div>
      <div class="rating-bars">${barsHTML}</div>
    </div>
    <div class="action-row">
      <button class="act-btn primary" onclick="alert('Opening Maps…')"><i class="ti ti-map-2" style="font-size:15px" aria-hidden="true"></i> Directions</button>
      <button class="act-btn secondary" onclick="alert('Calling…')"><i class="ti ti-phone" style="font-size:15px" aria-hidden="true"></i> Call</button>
    </div>
    <div class="services-title">Services</div>
    <div class="services-list">${store.services.map(s=>`<span class="svc-tag">${s}</span>`).join('')}</div>
    <div class="reviews-title">Customer Reviews (${store.reviews.toLocaleString()})</div>
    ${revsHTML}`;
  const overlay=document.getElementById('detailOverlay');
  overlay.style.display='flex';
  overlay.style.animation='none';
  document.getElementById('detailSheet').style.cssText='transform:translateY(100%);transition:transform .3s cubic-bezier(.32,.72,0,1);';
  requestAnimationFrame(()=>requestAnimationFrame(()=>{
    document.getElementById('detailSheet').style.transform='translateY(0)';
  }));
}

function closeDetail(e){
  if(e&&e.target!==document.getElementById('detailOverlay')&&!e.target.classList.contains('detail-close')&&!e.currentTarget.classList.contains('detail-close')) return;
  document.getElementById('detailSheet').style.transform='translateY(100%)';
  setTimeout(()=>document.getElementById('detailOverlay').style.display='none',300);
}

const styleEl=document.createElement('style');
styleEl.textContent='@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}';
document.head.appendChild(styleEl);

setTimeout(()=>{
  document.getElementById('loading').style.display='none';
  renderList(getFiltered());
},1200);
</script>
