
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Syne:wght@700&display=swap');
  *{box-sizing:border-box;margin:0;padding:0;}
  :root{
    --bg:#0D0D12;--surface:#16161E;--surface2:#1E1E28;--border:#2A2A38;
    --accent:#6C63FF;--accent2:#FF6B6B;--gold:#FFD166;--teal:#06D6A0;
    --text:#F0F0F8;--muted:#888899;--tag:#1E1E30;
  }
  body{background:var(--bg);font-family:'DM Sans',sans-serif;color:var(--text);min-height:600px;}
  .phone{width:380px;min-height:640px;background:var(--bg);overflow:hidden;position:relative;}

  .status-bar{display:flex;justify-content:space-between;align-items:center;padding:10px 20px 4px;font-size:12px;color:var(--muted);}
  .status-time{font-weight:600;font-size:13px;color:var(--text);}
  .header{padding:12px 20px 8px;}
  .header-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;}
  .greeting{font-size:11px;color:var(--muted);letter-spacing:.05em;text-transform:uppercase;}
  .title{font-family:'Syne',sans-serif;font-size:24px;font-weight:700;color:var(--text);line-height:1.1;}
  .loc-badge{display:flex;align-items:center;gap:5px;background:var(--surface2);border:0.5px solid var(--border);border-radius:20px;padding:5px 10px;font-size:11px;color:var(--teal);}
  .avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;}

  .search-wrap{padding:0 20px 10px;}
  .search-box{display:flex;align-items:center;gap:10px;background:var(--surface);border:0.5px solid var(--border);border-radius:14px;padding:10px 14px;}
  .search-box input{background:none;border:none;outline:none;color:var(--text);font-size:14px;flex:1;font-family:'DM Sans',sans-serif;}
  .search-box input::placeholder{color:var(--muted);}
  .filter-btn{background:var(--accent);border:none;border-radius:10px;width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#fff;flex-shrink:0;}

  .sort-row{display:flex;gap:8px;padding:4px 20px 10px;overflow-x:auto;scrollbar-width:none;}
  .sort-row::-webkit-scrollbar{display:none;}
  .chip{white-space:nowrap;font-size:12px;padding:6px 14px;border-radius:20px;border:0.5px solid var(--border);background:var(--surface);color:var(--muted);cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif;}
  .chip.active{background:var(--accent);border-color:var(--accent);color:#fff;font-weight:500;}

  .filter-row{display:flex;gap:8px;padding:0 20px 12px;overflow-x:auto;scrollbar-width:none;}
  .filter-row::-webkit-scrollbar{display:none;}
  .ftag{white-space:nowrap;font-size:11px;padding:5px 12px;border-radius:20px;border:0.5px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;transition:all .15s;font-family:'DM Sans',sans-serif;}
  .ftag.on{background:rgba(108,99,255,.15);border-color:var(--accent);color:var(--accent);}

  .section-label{padding:0 20px 8px;font-size:11px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;}

  .list{padding:0 16px;display:flex;flex-direction:column;gap:10px;padding-bottom:100px;}

  .card{background:var(--surface);border:0.5px solid var(--border);border-radius:18px;padding:14px 16px;cursor:pointer;transition:transform .15s, border-color .15s;position:relative;overflow:hidden;}
  .card:active{transform:scale(.98);}
  .card.top{border-color:rgba(108,99,255,.4);}
  .card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,transparent);}
  .card.top::before{background:linear-gradient(90deg,var(--accent),var(--accent2));}

  .card-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;}
  .store-name{font-size:15px;font-weight:600;color:var(--text);line-height:1.2;}
  .store-name a{color:var(--text);text-decoration:none;}
  .store-name a:hover{color:var(--accent);}
  .badges{display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;margin-left:8px;}
  .badge-top{font-size:9px;font-weight:600;letter-spacing:.06em;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;padding:3px 8px;border-radius:10px;text-transform:uppercase;}
  .badge-open{font-size:10px;padding:3px 9px;border-radius:10px;font-weight:500;}
  .badge-open.open{background:rgba(6,214,160,.15);color:var(--teal);}
  .badge-open.closed{background:rgba(255,107,107,.12);color:var(--accent2);}

  .stars-row{display:flex;align-items:center;gap:6px;margin-bottom:6px;}
  .stars{display:flex;gap:1px;}
  .star{font-size:13px;}
  .star.full{color:var(--gold);}
  .star.half{color:var(--gold);opacity:.6;}
  .star.empty{color:var(--border);}
  .rating-num{font-size:13px;font-weight:600;color:var(--gold);}
  .review-count{font-size:11px;color:var(--muted);}

  .addr-row{display:flex;align-items:center;gap:5px;margin-bottom:8px;}
  .addr-text{font-size:11px;color:var(--muted);}
  .dist-badge{font-size:10px;color:var(--accent);background:rgba(108,99,255,.1);padding:2px 8px;border-radius:8px;margin-left:auto;}

  .tags{display:flex;flex-wrap:wrap;gap:5px;}
  .tag{font-size:10px;padding:3px 9px;border-radius:8px;background:var(--tag);color:var(--muted);border:0.5px solid var(--border);}

  .detail-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.75);display:flex;align-items:flex-end;justify-content:center;z-index:100;display:none;}
  .detail-sheet{background:var(--surface);border-radius:24px 24px 0 0;padding:20px;width:380px;max-height:85vh;overflow-y:auto;}
  .drag-handle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 16px;}
  .detail-close{position:absolute;top:20px;right:20px;background:var(--surface2);border:none;border-radius:50%;width:30px;height:30px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);}
  .detail-title{font-family:'Syne',sans-serif;font-size:20px;font-weight:700;margin-bottom:4px;}
  .detail-addr{font-size:12px;color:var(--muted);margin-bottom:14px;}
  .detail-stars{display:flex;align-items:center;gap:8px;margin-bottom:16px;}
  .big-rating{font-size:36px;font-weight:700;color:var(--gold);font-family:'Syne',sans-serif;}
  .rating-bars{flex:1;}
  .bar-row{display:flex;align-items:center;gap:6px;margin-bottom:3px;}
  .bar-label{font-size:10px;color:var(--muted);width:8px;}
  .bar-track{flex:1;height:4px;background:var(--border);border-radius:2px;overflow:hidden;}
  .bar-fill{height:100%;background:var(--gold);border-radius:2px;}
  .action-row{display:flex;gap:10px;margin-bottom:18px;}
  .act-btn{flex:1;padding:12px;border-radius:14px;border:none;font-size:13px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;display:flex;align-items:center;justify-content:center;gap:6px;}
  .act-btn.primary{background:var(--accent);color:#fff;}
  .act-btn.secondary{background:var(--surface2);color:var(--text);border:0.5px solid var(--border);}
  .services-title{font-size:12px;color:var(--muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:.06em;}
  .services-list{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:18px;}
  .svc-tag{font-size:12px;padding:6px 12px;border-radius:10px;background:rgba(108,99,255,.1);color:var(--accent);border:0.5px solid rgba(108,99,255,.3);}
  .reviews-title{font-size:12px;color:var(--muted);margin-bottom:10px;text-transform:uppercase;letter-spacing:.06em;}
  .review-card{background:var(--surface2);border-radius:12px;padding:12px;margin-bottom:8px;}
  .rev-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
  .rev-author{font-size:13px;font-weight:500;}
  .rev-stars{display:flex;gap:1px;}
  .rev-text{font-size:12px;color:var(--muted);line-height:1.5;}

  .empty-state{text-align:center;padding:48px 24px;color:var(--muted);}
  .empty-icon{font-size:40px;margin-bottom:12px;}
  .empty-title{font-size:16px;font-weight:600;color:var(--text);margin-bottom:6px;}

  .skeleton{background:var(--surface);border-radius:18px;padding:14px 16px;margin:0 16px 10px;}
  .sk-line{background:var(--surface2);border-radius:4px;height:12px;margin-bottom:8px;animation:shimmer 1.4s infinite;}
  .sk-line.short{width:60%;}
  .sk-line.mid{width:80%;}
  @keyframes shimmer{0%,100%{opacity:.4}50%{opacity:.8}}

  .navbar{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:380px;background:var(--surface);border-top:0.5px solid var(--border);display:flex;justify-content:space-around;padding:10px 0 20px;}
  .nav-item{display:flex;flex-direction:column;align-items:center;gap:3px;font-size:9px;color:var(--muted);cursor:pointer;}
  .nav-item.active{color:var(--accent);}
  .nav-dot{width:4px;height:4px;border-radius:50%;background:var(--accent);opacity:0;}
  .nav-item.active .nav-dot{opacity:1;}
</style>

