    <div class="skeleton"><div class="sk-line"></div><div class="sk-line short"></div><div class="sk-line mid"></div></div>
    <div class="skeleton"><div class="sk-line mid"></div><div class="sk-line"></div><div class="sk-line short"></div></div>
  </div>

  <div id="storeList" style="display:none">
    <div class="section-label" id="resultCount"></div>
    <div class="list" id="cardsContainer"></div>
  </div>

  <div id="emptyState" class="empty-state" style="display:none">
    <div class="empty-icon">🔍</div>
    <div class="empty-title">No shops found</div>
    <p style="font-size:13px">Try adjusting your search or filters.</p>
  </div>

  <div class="navbar">
    <div class="nav-item"><i class="ti ti-home" style="font-size:20px" aria-hidden="true"></i><span>Home</span><div class="nav-dot"></div></div>
    <div class="nav-item active"><i class="ti ti-map" style="font-size:20px" aria-hidden="true"></i><span>Shops</span><div class="nav-dot"></div></div>
    <div class="nav-item"><i class="ti ti-tool" style="font-size:20px" aria-hidden="true"></i><span>Repair</span><div class="nav-dot"></div></div>
    <div class="nav-item"><i class="ti ti-user" style="font-size:20px" aria-hidden="true"></i><span>Profile</span><div class="nav-dot"></div></div>
  </div>
</div>

<div class="detail-overlay" id="detailOverlay" onclick="closeDetail(event)">
  <div class="detail-sheet" id="detailSheet">
    <div class="drag-handle"></div>
